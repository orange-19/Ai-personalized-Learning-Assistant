# ── AI Provider ──────────────────────────────────────────────
# Which AI provider to use: "grok" | "anthropic" | "openai"
AI_PROVIDER=grok


# ── Grok (xAI) ───────────────────────────────────────────────
XAI_API_KEY=xai-eUYGK6ohEnZBHWy6z9DM8BtNDWojh9XeK9ZD8ARltKc8XabBj3u1R0B520qP61B0Jo1kDkGXYrz8ZxWy
GROK_API_BASE=https://api.x.ai/v1
AI_MODEL=grok-3


