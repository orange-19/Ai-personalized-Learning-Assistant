# ============================================================
# PPLA — .env.example
# Safe template — commit this, NOT .env
# Copy to .env and fill in your actual values.
# ============================================================


# ── AI Provider ──────────────────────────────────────────────
# Which AI provider to use: "grok" | "anthropic" | "openai"
AI_PROVIDER=grok


# ── Grok (xAI) ───────────────────────────────────────────────
# XAI_API_KEY=your_xai_api_key_here
# GROK_API_BASE=https://api.x.ai/v1
# AI_MODEL=grok-3


# ── Anthropic (Claude) ───────────────────────────────────────
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-20250514


# ── OpenAI ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# AI_MODEL=gpt-4o


# ── Flask Server ─────────────────────────────────────────────
PPLA_HOST=0.0.0.0
PPLA_PORT=5000
PPLA_DEBUG=true


# ── AI Generation ────────────────────────────────────────────
AI_MAX_TOKENS=4096
